<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Italum System Window | Review & Contact</title>
  <meta name="description" content="Premium aluminium windows by Italum System Window. Leave a review, call, WhatsApp, open location, or copy review drafts from one clean mobile page." />
  <style>
    :root {
      --bg: #f7f1e9;
      --card: rgba(255,255,255,0.86);
      --line: #e8ded2;
      --text: #171717;
      --muted: #6b6258;
      --brand: #8b5a2b;
      --brand-dark: #2f251c;
      --shadow: 0 18px 50px rgba(0,0,0,.08);
      --radius: 28px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(139,90,43,.14), transparent 42%),
        linear-gradient(180deg, #f7f1e9 0%, #fff 46%, #faf7f2 100%);
    }
    a { color: inherit; text-decoration: none; }
    .wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 18px 16px 90px;
    }
    .hero, .panel {
      background: var(--card);
      backdrop-filter: blur(12px);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .hero { padding: 22px; overflow: hidden; }
    .grid {
      display: grid;
      gap: 22px;
    }
    @media (min-width: 900px) {
      .grid-2 { grid-template-columns: 1.08fr .92fr; }
    }
    .topline {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .logoBox {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .logoCard {
      width: 118px;
      min-width: 118px;
      height: 118px;
      display: grid;
      place-items: center;
      border-radius: 30px;
      background: white;
      border: 2px solid rgba(139,90,43,.18);
      box-shadow: 0 14px 34px rgba(139,90,43,.18);
      overflow: hidden;
    }
    .logoCard img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 8px;
      display: block;
    }
    .eyebrow {
      margin: 0;
      color: var(--brand);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .28em;
      text-transform: uppercase;
    }
    h1 {
      margin: 4px 0 0;
      font-size: clamp(2rem, 4vw, 4rem);
      line-height: 1.04;
      letter-spacing: -.04em;
    }
    .lead {
      margin: 14px 0 0;
      color: var(--muted);
      line-height: 1.8;
      font-size: 1rem;
      max-width: 62ch;
    }
    .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(139,90,43,.14);
      color: #7b4f25;
      background: rgba(139,90,43,.06);
      padding: 9px 12px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
    }
    .actions {
      display: grid;
      gap: 12px;
      margin-top: 22px;
    }
    @media (min-width: 640px) {
      .actions { grid-template-columns: 1fr 1fr; }
      .actions .full { grid-column: 1 / -1; }
    }
    .btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      width: 100%;
      padding: 16px 18px;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 8px 20px rgba(0,0,0,.04);
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, border-color .18s ease;
    }
    .btn:hover { transform: translateY(-1px); border-color: #d6c8b8; background: #fcfbf9; }
    .btn.primary {
      background: #111;
      color: white;
      border-color: #111;
    }
    .btn.primary:hover { background: #222; }
    .btn .left {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .icon {
      width: 44px;
      height: 44px;
      display: inline-grid;
      place-items: center;
      border-radius: 16px;
      background: rgba(139,90,43,.10);
      color: var(--brand);
      flex: none;
    }
    .btn.primary .icon {
      background: rgba(255,255,255,.12);
      color: white;
    }
    .arrow {
      opacity: .62;
      font-size: 18px;
      flex: none;
    }
    .panel {
      padding: 22px;
    }
    .sectionTitle {
      margin: 0;
      font-size: 13px;
      color: var(--brand);
      font-weight: 800;
      letter-spacing: .28em;
      text-transform: uppercase;
    }
    .sectionHead {
      margin: 8px 0 0;
      font-size: clamp(1.55rem, 2vw, 2.1rem);
      line-height: 1.1;
      letter-spacing: -.03em;
    }
    .sectionSub {
      margin: 10px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }
    .reviewList {
      display: grid;
      gap: 12px;
      margin-top: 22px;
    }
    .reviewCard {
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 22px;
      padding: 16px;
      display: grid;
      gap: 14px;
    }
    @media (min-width: 740px) {
      .reviewCard {
        grid-template-columns: 1fr auto;
        align-items: start;
      }
    }
    .reviewTitle {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #7b4f25;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .22em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .reviewText {
      margin: 0;
      color: #2a2724;
      line-height: 1.75;
      font-size: 15px;
    }
    .reviewNote {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.6;
    }
    .copyBtn {
      white-space: nowrap;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 16px;
      padding: 12px 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, border-color .18s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      justify-content: center;
    }
    .copyBtn:hover { transform: translateY(-1px); border-color: #d6c8b8; background: #faf8f5; }
    .sideBox {
      border-radius: 24px;
      border: 1px solid var(--line);
      background: #fff;
      padding: 18px;
    }
    .miniList {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }
    .miniItem {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      border-radius: 18px;
      background: #faf8f5;
      border: 1px solid #ebe2d8;
      font-size: 14px;
      font-weight: 600;
    }
    .miniItem span {
      display: inline-flex;
      align-items: center;
      gap: 10px;
    }
    .qrWrap {
      display: grid;
      gap: 16px;
      margin-top: 22px;
    }
    .qrTool {
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 16px;
      background: #fff;
    }
    .qrRow {
      display: grid;
      gap: 12px;
    }
    @media (min-width: 760px) {
      .qrRow { grid-template-columns: 1.1fr auto; align-items: start; }
    }
    .input {
      width: 100%;
      border: 1px solid var(--line);
      background: #fcfbf9;
      border-radius: 16px;
      padding: 14px 16px;
      font-size: 15px;
      outline: none;
    }
    .input:focus { border-color: #cdb79f; box-shadow: 0 0 0 4px rgba(139,90,43,.08); }
    .small {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
    }
    .qrBox {
      display: grid;
      place-items: center;
      gap: 12px;
      padding: 18px;
      border-radius: 22px;
      border: 1px dashed #d8c9b7;
      background: linear-gradient(180deg, #fff, #fbf8f3);
      min-height: 320px;
    }
    #qrcode canvas, #qrcode img {
      border-radius: 18px;
      box-shadow: 0 12px 28px rgba(0,0,0,.08);
    }
    .footerBar {
      margin-top: 18px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: #111;
      color: #fff;
      padding: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 18px;
      justify-content: space-between;
      align-items: center;
    }
    .sticky {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255,255,255,.96);
      backdrop-filter: blur(12px);
      border-top: 1px solid #eadfce;
      padding: 12px 12px calc(12px + env(safe-area-inset-bottom));
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      z-index: 60;
    }
    .sticky .btn { padding: 14px 16px; }
    @media (min-width: 900px) {
      .sticky { display: none; }
    }
    .toast {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: 92px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 12px 16px;
      box-shadow: var(--shadow);
      z-index: 80;
      font-size: 14px;
      font-weight: 600;
    }
    .highlight {
      border: 2px solid rgba(139,90,43,.26);
      box-shadow: 0 18px 38px rgba(139,90,43,.18);
      background: #fff;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="hero">
      <div class="topline">
        <div class="logoBox">
          <div class="logoCard highlight">
            <img src="data:image/jpeg;base64," alt="Italum System Window logo" />
          </div>
          <div>
            <p class="eyebrow">Premium Review Portal</p>
            <h1>Italum System Window</h1>
          </div>
        </div>
      </div>

      <div class="pills">
        <span class="pill">Premium aluminium windows</span>
        <span class="pill">Trusted customer experience</span>
        <span class="pill">Brown brand palette</span>
      </div>

      <p class="lead">
        Scan the QR code and open this page first. Then choose review, WhatsApp, call, location, or copy a review draft.
        The layout is mobile-first and built for quick customer action.
      </p>

      <div class="actions">
        <button class="btn primary" onclick="openExternal(REVIEW_URL)">
          <span class="left"><span class="icon">★</span> Leave Review</span><span class="arrow">↗</span>
        </button>
        <button class="btn" onclick="openExternal(WHATSAPP_URL)">
          <span class="left"><span class="icon">✆</span> WhatsApp Us</span><span class="arrow">↗</span>
        </button>
        <button class="btn" onclick="window.location.href=CALL_URL">
          <span class="left"><span class="icon">☎</span> Call Now</span><span class="arrow">↗</span>
        </button>
        <button class="btn" onclick="openExternal(REVIEW_URL)">
          <span class="left"><span class="icon">⌖</span> Open Location</span><span class="arrow">↗</span>
        </button>
        <button class="btn full" onclick="copyText(REVIEW_URL)">
          <span class="left"><span class="icon">⧉</span> Copy Review Link</span><span class="arrow">↗</span>
        </button>
      </div>
    </header>

    <div class="grid grid-2" style="margin-top: 18px;">
      <section class="panel">
        <p class="sectionTitle">Review drafts</p>
        <h2 class="sectionHead">10 sample review drafts with copy buttons</h2>
        <p class="sectionSub">
          Use these only as drafts. A real customer should edit them to reflect the true experience before posting.
        </p>

        <div class="reviewList" id="reviewList"></div>
      </section>

      <aside class="grid">
        <div class="panel sideBox">
          <p class="sectionTitle">How it works</p>
          <h2 class="sectionHead">Simple flow</h2>
          <p class="sectionSub">
            1. Scan QR<br />
            2. Open this landing page<br />
            3. Tap review, WhatsApp, call, or location<br />
            4. Copy a draft and paste it into Google review
          </p>

          <div class="miniList">
            <div class="miniItem"><span>✦ Elegant finish</span><span>→</span></div>
            <div class="miniItem"><span>✦ Fast mobile access</span><span>→</span></div>
            <div class="miniItem"><span>✦ Direct review flow</span><span>→</span></div>
          </div>
        </div>

        <div class="panel sideBox">
          <p class="sectionTitle">Quick contact</p>
          <h2 class="sectionHead">One tap actions</h2>
          <div class="miniList">
            <button class="miniItem" style="cursor:pointer; text-align:left;" onclick="openExternal(WHATSAPP_URL)"><span>✆ WhatsApp</span><span>↗</span></button>
            <button class="miniItem" style="cursor:pointer; text-align:left;" onclick="window.location.href=CALL_URL"><span>☎ Call</span><span>↗</span></button>
            <button class="miniItem" style="cursor:pointer; text-align:left;" onclick="openExternal(REVIEW_URL)"><span>⌖ Google page</span><span>↗</span></button>
          </div>
          <p class="small" style="margin-top:12px;">WhatsApp: +91 95864 39221<br/>Call: +91 95864 39221</p>
        </div>
      </aside>
    </div>

    <section class="panel" style="margin-top: 18px;">
      <p class="sectionTitle">QR code</p>
      <h2 class="sectionHead">Generate the QR code for the live page</h2>
      <p class="sectionSub">
        Paste the public URL of this website below. The QR image will point to that page, so customers can scan it and land here directly.
      </p>

      <div class="qrWrap">
        <div class="qrTool">
          <div class="qrRow">
            <div>
              <label for="pageUrl" class="small" style="display:block; margin-bottom:8px; font-weight:700; color:#2a2724;">Your live page URL</label>
              <input id="pageUrl" class="input" type="url" value="https://your-live-page-url-here" />
              <p class="small" style="margin:10px 0 0;">
                Replace the sample URL with the actual website link after hosting.
              </p>
              <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:14px;">
                <button class="copyBtn" onclick="generateQr()">Generate QR</button>
                <button class="copyBtn" onclick="downloadQr()">Download QR PNG</button>
                <button class="copyBtn" onclick="copyText(document.getElementById('pageUrl').value)">Copy page URL</button>
              </div>
            </div>
            <div class="qrBox">
              <div id="qrcode"></div>
              <div class="small" id="qrHint">QR preview will appear here.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="panel" style="margin-top: 18px;">
      <p class="sectionTitle">Honest review request</p>
      <h2 class="sectionHead">Customer-facing message</h2>
      <p class="sectionSub" style="max-width: 70ch;">
        Your feedback matters. If you had a good experience with Italum System Window, please leave us an honest Google review.
      </p>
      <div class="footerBar">
        <strong>Italum System Window</strong>
        <span>Premium aluminium windows and system solutions</span>
      </div>
    </section>
  </div>

  <div class="sticky">
    <button class="btn primary" onclick="openExternal(REVIEW_URL)"><span class="left"><span class="icon">★</span> Leave Review</span><span class="arrow">↗</span></button>
    <button class="btn" onclick="openExternal(WHATSAPP_URL)"><span class="left"><span class="icon">✆</span> WhatsApp</span><span class="arrow">↗</span></button>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js"></script>
  <script>
    const BUSINESS_NAME = "Italum System Window";
    const REVIEW_URL = "https://maps.app.goo.gl/d7PbZq24p7StFAUN6";
    const WHATSAPP_URL = "https://wa.me/919586439221";
    const CALL_URL = "tel:+919586439221";
    const REVIEWS = [
      "Very satisfied with the aluminium window quality and finishing. The look is premium and the overall work feels well made.",
      "Professional service, smooth installation, and a clean final result. The windows improved the appearance of the space.",
      "The windows look elegant and modern. The material feels strong, and the finishing is neat and refined.",
      "Excellent workmanship and clear communication throughout the project. The installation was handled properly.",
      "Good product quality with a premium appearance. The aluminium windows fit well and operate smoothly.",
      "The team was helpful and the work was completed neatly. The final result looks clean and professional.",
      "Timely service, proper installation, and strong attention to detail. The end result is impressive.",
      "The aluminium windows feel durable and well finished. They suit the design of the home very well.",
      "A reliable company for premium system windows. The service experience was simple and efficient.",
      "The overall quality, finishing, and support were excellent. A very good experience from start to finish."
    ];

    function openExternal(url) {
      window.open(url, "_blank", "noopener,noreferrer");
    }

    function showToast(msg) {
      let t = document.getElementById("toast");
      if (!t) {
        t = document.createElement("div");
        t.id = "toast";
        t.className = "toast";
        document.body.appendChild(t);
      }
      t.textContent = msg;
      t.style.display = "block";
      clearTimeout(window.__toastTimer);
      window.__toastTimer = setTimeout(() => {
        t.remove();
      }, 1700);
    }

    async function copyText(text) {
      try {
        await navigator.clipboard.writeText(text);
        showToast("Copied to clipboard");
      } catch (e) {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        document.execCommand("copy");
        ta.remove();
        showToast("Copied to clipboard");
      }
    }

    function buildReviewCards() {
      const el = document.getElementById("reviewList");
      el.innerHTML = "";
      REVIEWS.forEach((text, i) => {
        const card = document.createElement("article");
        card.className = "reviewCard";
        card.innerHTML = `
          <div>
            <div class="reviewTitle">★ Draft ${i + 1}</div>
            <p class="reviewText"></p>
            <p class="reviewNote">Copy this text, edit it to match the real experience, then paste it into Google review.</p>
          </div>
          <button class="copyBtn" type="button">Copy this review</button>
        `;
        card.querySelector(".reviewText").textContent = text;
        card.querySelector("button").addEventListener("click", () => {
          copyText(text);
        });
        el.appendChild(card);
      });
    }

    async function generateQr() {
      const input = document.getElementById("pageUrl");
      const value = (input.value || "").trim();
      if (!value) {
        showToast("Add your live page URL");
        return;
      }
      const target = document.getElementById("qrcode");
      target.innerHTML = "";
      try {
        const canvas = document.createElement("canvas");
        await QRCode.toCanvas(canvas, value, {
          width: 280,
          margin: 2,
          errorCorrectionLevel: "M",
          color: {
            dark: "#111111",
            light: "#ffffff"
          }
        });
        const wrapper = document.createElement("div");
        wrapper.style.background = "#fff";
        wrapper.style.padding = "20px";
        wrapper.style.borderRadius = "18px";
        wrapper.style.boxShadow = "0 12px 28px rgba(0,0,0,.08)";
        wrapper.appendChild(canvas);
        target.appendChild(wrapper);
        document.getElementById("qrHint").textContent = "QR generated successfully.";
        showToast("QR generated");
      } catch (e) {
        document.getElementById("qrHint").textContent = "QR generation failed. Check the URL and try again.";
        showToast("QR generation failed");
      }
    }

    function downloadQr() {
      const target = document.getElementById("qrcode");
      const canvas = target.querySelector("canvas");
      if (!canvas) {
        showToast("Generate the QR first");
        return;
      }
      const link = document.createElement("a");
      link.href = canvas.toDataURL("image/png");
      link.download = "italum-qr.png";
      link.click();
    }

    buildReviewCards();
    generateQr();
  </script>
</body>
</html>
